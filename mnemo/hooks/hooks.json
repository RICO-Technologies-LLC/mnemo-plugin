{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'P=\"${CLAUDE_PLUGIN_ROOT}\"; P=\"${P//\\\\//}\"; bash \"$P/hooks-handlers/session-start.sh\"'",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'P=\"${CLAUDE_PLUGIN_ROOT}\"; P=\"${P//\\\\//}\"; bash \"$P/hooks-handlers/stop-check.sh\"'",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'P=\"${CLAUDE_PLUGIN_ROOT}\"; P=\"${P//\\\\//}\"; bash \"$P/hooks-handlers/precompact-check.sh\"'",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'P=\"${CLAUDE_PLUGIN_ROOT}\"; P=\"${P//\\\\//}\"; bash \"$P/hooks-handlers/plan-accepted-check.sh\"'",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
