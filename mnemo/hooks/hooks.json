{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks-handlers/session-init.sh\"",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=~/.claude/mnemo/hooks-handlers/hook-guard.sh; [ -f \"$f\" ] && bash \"$f\" stop-check || true'",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=~/.claude/mnemo/hooks-handlers/hook-guard.sh; [ -f \"$f\" ] && bash \"$f\" precompact-check || true'",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=~/.claude/mnemo/hooks-handlers/hook-guard.sh; [ -f \"$f\" ] && bash \"$f\" plan-accepted-check || true'",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
