{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'P=\"${CLAUDE_PLUGIN_ROOT}\"; P=\"${P//\\\\//}\"; mkdir -p \"${HOME}/.claude/mnemo/hooks\" && cp \"$P\"/hooks-handlers/*.sh \"${HOME}/.claude/mnemo/hooks/\" && bash \"${HOME}/.claude/mnemo/hooks/session-start.sh\"'",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${HOME}/.claude/mnemo/hooks/stop-check.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${HOME}/.claude/mnemo/hooks/precompact-check.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${HOME}/.claude/mnemo/hooks/plan-accepted-check.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
